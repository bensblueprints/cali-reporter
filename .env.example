# Cali Reporter env

# Public site URL (no trailing slash)
SITE_URL=https://calireporter.com

# --- Admin auth ---
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=
# Generate: node deploy/generate-password-hash.js 'YourPassword'
# IMPORTANT: Next.js env loader expands $VAR references even in quoted values.
# bcrypt hashes contain '$' — escape EACH ONE as \$. Example:
#   ADMIN_PASSWORD_HASH=\$2a\$12\$DRJv/9cmVEz0U...
# (Three \$ for "$2a$12$..." plus any internal '$' inside the salt portion.)
ADMIN_PASSWORD_HASH=

# --- Database ---
DATABASE_PATH=./data/cali-reporter.db

# --- AI providers ---
# Text rewriting
AI_TEXT_PROVIDER=anthropic        # anthropic | openai | none
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Image generation
AI_IMAGE_PROVIDER=replicate       # replicate | openai | none
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-schnell

# --- Aggregator ---
# Per-run cap, total across all feeds
AGGREGATE_MAX_PER_RUN=12
# Per-feed cap
AGGREGATE_MAX_PER_FEED=4
