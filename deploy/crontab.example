# Cali Reporter — aggregator cron (UTC) for 7:30 AM / 12:30 PM / 6:30 PM Pacific
# Pacific is UTC-8 (PST) / UTC-7 (PDT). These rows assume PT and the host server
# running in UTC. Adjust if your server is in PT, or pin TZ=America/Los_Angeles.
#
# Install on the server with:
#   crontab -e
# and paste these lines.

# 7:30 AM Pacific
30 14 * * * docker exec cali-reporter node /app/scripts/aggregate.js >> /var/log/cali-reporter-aggregate.log 2>&1

# 12:30 PM Pacific
30 19 * * * docker exec cali-reporter node /app/scripts/aggregate.js >> /var/log/cali-reporter-aggregate.log 2>&1

# 6:30 PM Pacific
30  1 * * * docker exec cali-reporter node /app/scripts/aggregate.js >> /var/log/cali-reporter-aggregate.log 2>&1

# Nightly DB backup at 3:15 AM Pacific
15 10 * * * docker exec cali-reporter sqlite3 /app/data/cali-reporter.db ".backup '/app/data/backup-$(date +\%F).db'" >> /var/log/cali-reporter-backup.log 2>&1
